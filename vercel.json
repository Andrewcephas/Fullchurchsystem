{
  "version": 2,
  "installCommand": "npm install && uv pip install -r requirements.txt --system",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "church_backend/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "church_backend/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "church_backend/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "dist/$1"
    }
  ]
}